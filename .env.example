# App
APP_NAME=RealEstateDispoSwarm
DEBUG=true
VERSION=1.0.0
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development

# Supabase
SUPABASE_URL=xxx
SUPABASE_KEY=xxx
SUPABASE_SERVICE_KEY=xxx

# Groq
GROQ_API_KEY=xxx
GROQ_MODEL=mixtral-8x7b-32768

# Gmail
GMAIL_ADDRESS=xxx
GMAIL_APP_PASSWORD=xxx

# Google Drive
GOOGLE_DRIVE_CLIENT_ID=xxx
GOOGLE_DRIVE_CLIENT_SECRET=xxx
GOOGLE_DRIVE_REFRESH_TOKEN=xxx

# HuggingFace token (for gated models, e.g. sentence-transformers)
HF_TOKEN=xxx

# Database (Docker Postgres for local dev)
DATABASE_URL=postgresql+asyncpg://dispo:dispo_secret@localhost:5432/dispo_db

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Gmail Daily Send Cap (Feature 1)
# ---------------------------------------------------------------------------
# GMAIL_DAILY_CAP=400
# GMAIL_TIMEZONE=Asia/Karachi

# ---------------------------------------------------------------------------
# Operator Identity — the AI speaks as this person (Feature 2)
# ---------------------------------------------------------------------------
# OPERATOR_NAME=Alex
# OPERATOR_FIRST_NAME=Alex
# OPERATOR_EMAIL_SIGNATURE=Best,\nAlex
# OPERATOR_TONE=conversational
# OPERATOR_NEVER_SAY=guaranteed,free,act now
# OPERATOR_CONTEXT=I've been investing in Texas real estate for 5 years. I work directly with sellers and buyers — no middlemen.
