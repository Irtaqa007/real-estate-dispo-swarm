# =============================================================================
# Real Estate Dispo Swarm — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# REQUIRED variables are marked. The app will refuse to start without them.

# =============================================================================
# App
# =============================================================================
APP_NAME=RealEstateDispoSwarm
DEBUG=false
VERSION=1.0.0
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
FORCE_IPV4=true

# =============================================================================
# Database (Supabase — Required)
# =============================================================================
# Connection string for Supabase using the connection pooler.
# Format: postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_role_key

# =============================================================================
# Groq AI (Required for email generation and reply classification)
# =============================================================================
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# =============================================================================
# Cohere (Required for email verification)
# =============================================================================
COHERE_API_KEY=your_cohere_key

# =============================================================================
# Gmail SMTP (Required for sending emails)
# =============================================================================
GMAIL_ADDRESS=your.email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# =============================================================================
# Gmail Daily Send Cap
# =============================================================================
# Hard ceiling before Gmail's ~500/day limit. Campaign sends are blocked
# when today's count reaches this cap. Reply sends are never blocked.
GMAIL_DAILY_CAP=400
# Timezone for midnight reset of the daily send counter (IANA timezone name).
GMAIL_TIMEZONE=Asia/Karachi

# =============================================================================
# Google Drive (Optional — for sharing property photos)
# =============================================================================
GOOGLE_DRIVE_CLIENT_ID=your_client_id
GOOGLE_DRIVE_CLIENT_SECRET=your_client_secret
GOOGLE_DRIVE_REFRESH_TOKEN=your_refresh_token

# =============================================================================
# HuggingFace (Required for embedding model download)
# =============================================================================
HF_TOKEN=your_hf_token

# =============================================================================
# PUBLIC BASE URL (Required for unsubscribe links)
# =============================================================================
BASE_URL=http://localhost:8000

# =============================================================================
# TITLE COMPANY EMAIL (Optional — for automated closing)
# =============================================================================
TITLE_COMPANY_EMAIL=title@company.com

# =============================================================================
# OPERATOR IDENTITY — REQUIRED (AI speaks as you in all communications)
# =============================================================================
# The app will refuse to start if OPERATOR_NAME is blank.
OPERATOR_NAME=Your Full Name
OPERATOR_FIRST_NAME=YourFirstName
# Email signature line. Use 
 for newlines. Example: "Best,
Your Name"
OPERATOR_EMAIL_SIGNATURE=Best,Your Name
# AI tone: "conversational", "formal", or "direct"
OPERATOR_TONE=conversational
# Comma-separated words/phrases the AI must never use
OPERATOR_NEVER_SAY=guaranteed,free,act now
# 1-2 sentences of personal context the AI can reference naturally
OPERATOR_CONTEXT=I invest in real estate directly with buyers and sellers.

# =============================================================================
# Frontend
# =============================================================================
NEXT_PUBLIC_API_URL=http://backend:8000
