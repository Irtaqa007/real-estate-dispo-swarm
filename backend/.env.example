# =============================================================================
# Real Estate Dispo Swarm — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# cp .env.example .env

# =============================================================================
# Database (Required)
# =============================================================================
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# =============================================================================
# Groq AI (Required for email generation and reply classification)
# =============================================================================
# GROQ_API_KEY=gsk_your_key_here

# =============================================================================
# Gmail SMTP (Required for sending emails)
# =============================================================================
# GMAIL_ADDRESS=your.email@gmail.com
# GMAIL_APP_PASSWORD=your_16_char_app_password

# =============================================================================
# Gmail Daily Send Cap (Feature 1)
# =============================================================================
# Hard ceiling before Gmail's ~500/day limit. Campaign sends are blocked
# when today's count reaches this cap. Reply sends are never blocked.
# GMAIL_DAILY_CAP=400

# Timezone for midnight reset of the daily send counter.
# Must be a valid IANA timezone name (Python zoneinfo).
# GMAIL_TIMEZONE=Asia/Karachi

# =============================================================================
# Operator Identity — the AI speaks as this person (Feature 2)
# =============================================================================
# The name the AI should use when writing emails and responding to buyers.
# OPERATOR_NAME=Alex
# OPERATOR_FIRST_NAME=Alex

# The email signature line appended to all AI-generated emails.
# Use \n for newlines. Example: "Best,\nAlex"
# OPERATOR_EMAIL_SIGNATURE=Best,\nAlex

# AI tone: "conversational", "formal", or "direct"
# OPERATOR_TONE=conversational

# Comma-separated words/phrases the AI must never use.
# Example: "guaranteed,free,act now,limited time"
# OPERATOR_NEVER_SAY=

# 1-2 sentences of personal context the AI can reference naturally.
# Example: "I've been investing in Texas real estate for 5 years.
# I work directly with sellers and buyers — no middlemen."
# OPERATOR_CONTEXT=

# =============================================================================
# Google Drive (Optional — for sharing property photos)
# =============================================================================
# GOOGLE_DRIVE_CLIENT_ID=your_client_id
# GOOGLE_DRIVE_CLIENT_SECRET=your_client_secret
# GOOGLE_DRIVE_REFRESH_TOKEN=your_refresh_token

# =============================================================================
# Title Company (Optional — for automated closing)
# =============================================================================
# TITLE_COMPANY_EMAIL=title@company.com

# =============================================================================
# Application
# =============================================================================
# BASE_URL=http://localhost:8000
# APP_NAME=RealEstateDispoSwarm
# DEBUG=true
# ENVIRONMENT=development
# FRONTEND_URL=http://localhost:3000
